# Приложение и демонстрационный режим.
APP_ENV=local
DEMO_MODE=false
DEMO_USER_LOGIN=demo
DEMO_USER_PASSWORD=demo12345
DEMO_ADMIN_LOGIN=admin
DEMO_ADMIN_PASSWORD=admin12345
DEMO_INITIAL_CREDIT=100.00
DEMO_NEWS_PATH=data/demo/lenta_demo.csv

# PostgreSQL.
POSTGRES_DB=semantic_news_novelty
POSTGRES_USER=semantic_news_novelty
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ.
RABBITMQ_USER=semantic_news_novelty
RABBITMQ_PASSWORD=change_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# Количество воркеров model-service.
MODEL_SERVICE_GPU_REPLICAS=1
MODEL_SERVICE_CPU_REPLICAS=0

# Очередь фоновой обработки новостей.
NEWS_VECTORIZATION_QUEUE=news_vectorization.jobs

# Диагностика базы данных.
SQLALCHEMY_ECHO=false

# Безопасность API. Обязательно замените секреты перед запуском.
PASSWORD_HASH_SECRET=change_me_password_hash_secret
ACCESS_TOKEN_SECRET=change_me_access_token_secret
ACCESS_TOKEN_TTL_MINUTES=1440

# Стоимость публикации новости.
NEWS_ADD_COST=1.00



# Настройки GPU и базовый образ GPU-воркера.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
PYTORCH_IMAGE=mirror.gcr.io/pytorch/pytorch:2.7.1-cuda12.8-cudnn9-runtime

# Кеш и доступ к моделям Hugging Face.
MODEL_SERVICE_HF_HOME=/app/.cache/huggingface
# Необязательный абсолютный путь к кешу на хосте; по умолчанию используется Docker volume.
MODEL_SERVICE_HF_CACHE=model_cache
# Отключает загрузку через Xet и использует обычный HTTP-механизм Hugging Face Hub.
HF_HUB_DISABLE_XET=1
# Необязательный токен: нужен для приватных моделей или повышенных лимитов Hub.
HF_TOKEN=

# Внешний HTTP-порт nginx.
NGINX_PORT=80

# Monitoring.
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
