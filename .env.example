APP_ENV=local

POSTGRES_DB=news_flow
POSTGRES_USER=news_flow
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

RABBITMQ_USER=news_flow
RABBITMQ_PASSWORD=change_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

NEWS_VECTORIZATION_QUEUE=news_vectorization.jobs
SQLALCHEMY_ECHO=false
PASSWORD_HASH_SECRET=change_me_password_hash_secret
ACCESS_TOKEN_SECRET=change_me_access_token_secret
ACCESS_TOKEN_TTL_MINUTES=1440
NEWS_ADD_COST=1.00
NEWS_SEARCH_COST=1.00
USE_LOCAL_MODEL=false
LOCAL_MODEL_SOURCE=/app/local_models/news-flow-ru-vectorization-mpnet/final
REMOTE_MODEL_SOURCE=/app/configs/model_registry/latest_model.json
HF_MODEL_ID=Korprus/news-flow-ru-vectorization-mpnet
HF_MODEL_REVISION=789ab95331d9abc4f5f23d1e3d5d24bb8af28086
HF_MODEL_DIR=/app/models/news-flow-ru-vectorization-mpnet/final
HF_MODEL_METADATA_PATH=/app/configs/model_registry/latest_model.json
PRELOAD_MODEL_FROM_HF=false
MODEL_SERVICE_HF_HOME=/app/.cache/huggingface
HF_HUB_DISABLE_XET=1
HF_TOKEN=
NGINX_PORT=80
